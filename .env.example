# ─────────────────────────────────────────────
# HemasHealth IQ — Backend Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only OPENAI_API_KEY is required to run locally
# with mock data. Everything else is optional until
# you connect a real database or go to production.
# ─────────────────────────────────────────────


# ── REQUIRED ─────────────────────────────────
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── SUPABASE (not needed while using mock_db) ─
# Get these from your Supabase project → Settings → API
# Use the "service_role" key (not the anon key) — it bypasses RLS
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx


# ── APP ───────────────────────────────────────
# "development" or "production"
APP_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
# Add your Vercel URL when you deploy
ALLOWED_ORIGINS=http://localhost:3000


# ── OPTIONAL: Google Cloud Translation ────────
# Only needed if you want Sinhala ↔ English translation
# Leave blank to skip — the agent still handles Sinhala via the LLM
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=